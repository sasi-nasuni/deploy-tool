# GitHub Personal Access Token (required)
# Used for cloning nasuni/nbn-daemon and nasuni/unity repos (use a token with repo scope)
GITHUB_PAT=ghp_your_token_here

# Directory where repos are cloned (default: ~/.deploy_tool/repos)
REPOS_BASE_PATH=~/.deploy_tool/repos

# Repo URLs (default to Nasuni repos)
NBN_DAEMON_REPO_URL=https://github.com/nasuni/nbn-daemon.git
UNITY_REPO_URL=https://github.com/nasuni/unity.git

# Deployment timeout in seconds (default: 1800 = 30 minutes)
DEPLOY_TIMEOUT_SECONDS=1800

# Server port (default: 8000)
SERVER_PORT=8000

# Optional frontend build directory for FastAPI static serving in production
# FRONTEND_DIST_PATH=../frontend/dist
